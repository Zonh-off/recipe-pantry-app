generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String?
  name          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  profile       Profile?
  pantryItems   PantryItem[]
  collections   Collection[]
  groceryItems  GroceryItem[]
  refreshTokens RefreshToken[]
}

model ProfileEntity {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  diet         String[]
  intolerances String[]
  cuisines     String[]
  goals        String[]
}

model PantryItem {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  ingredientId Int // Normalized ID from Spoonacular
  name         String
  amount       Float?
  unit         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, ingredientId])
}

model CollectionEntity {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  recipeIds Int[] // IDs from Spoonacular
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GroceryItemEntity {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  amount    Float?
  unit      String?
  checked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}
