generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  profile      Profile?
  pantryItems  PantryItem[]
  collections  Collection[]
  groceryItems GroceryItem[]
}

model Profile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  diet         String[]
  intolerances String[]
  cuisines     String[]
  goals        String[]
}

model PantryItem {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  ingredientId Int // Normalized ID from Spoonacular
  name         String
  amount       Float?
  unit         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, ingredientId])
}

model Collection {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  recipeIds Int[] // IDs from Spoonacular
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GroceryItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  amount    Float?
  unit      String?
  checked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
